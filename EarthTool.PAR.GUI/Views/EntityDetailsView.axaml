<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:selectors="using:EarthTool.PAR.GUI.Selectors"
             xmlns:models="clr-namespace:EarthTool.PAR.GUI.Models"
             x:Class="EarthTool.PAR.GUI.Views.EntityDetailsView"
             x:DataType="models:ParameterTreeNode">
    
    <UserControl.Resources>
        <selectors:EntityTemplateSelector x:Key="EntityTemplateSelector" />
    </UserControl.Resources>
    
    <ContentControl Content="{Binding Entity}" 
                    ContentTemplate="{StaticResource EntityTemplateSelector}" />
</UserControl>
