<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:EarthTool.PAR.Models"
             x:Class="EarthTool.PAR.GUI.Views.EntityTemplates.BuilderTemplate"
             x:DataType="local:Builder">
    <ScrollViewer>
        <StackPanel Margin="10">
            <Label Content="Builder Details:" FontWeight="Bold" FontSize="16" />
            
            <Label Content="Name:" />
            <TextBox Text="{Binding Name}" />
            
            <Label Content="Wall Id:" />
            <TextBox Text="{Binding WallId}" />
            
            <Label Content="Bridge Id:" />
            <TextBox Text="{Binding BridgeId}" />
            
            <Label Content="Tunnel Number:" />
            <TextBox Text="{Binding TunnelNumber}" />
            
            <Label Content="Road Build Time:" />
            <TextBox Text="{Binding RoadBuildTime}" />
            
            <Label Content="Flat Build Time:" />
            <TextBox Text="{Binding FlatBuildTime}" />
            
            <Label Content="Trench Build Time:" />
            <TextBox Text="{Binding TrenchBuildTime}" />
            
            <Label Content="Tunnel Build Time:" />
            <TextBox Text="{Binding TunnelBuildTime}" />
            
            <Label Content="Build Object Animation Angle:" />
            <TextBox Text="{Binding BuildObjectAnimationAngle}" />
            
            <Label Content="Dig Normal Animation Angle:" />
            <TextBox Text="{Binding DigNormalAnimationAngle}" />
            
            <Label Content="Dig Low Animation Angle:" />
            <TextBox Text="{Binding DigLowAnimationAngle}" />
            
            <!-- Building animations -->
            <Label Content="Anim Build Object Start Start:" />
            <TextBox Text="{Binding AnimBuildObjectStartStart}" />
            
            <Label Content="Anim Build Object Start End:" />
            <TextBox Text="{Binding AnimBuildObjectStartEnd}" />
            
            <Label Content="Anim Build Object Work Start:" />
            <TextBox Text="{Binding AnimBuildObjectWorkStart}" />
            
            <Label Content="Anim Build Object Work End:" />
            <TextBox Text="{Binding AnimBuildObjectWorkEnd}" />
            
            <Label Content="Anim Build Object End Start:" />
            <TextBox Text="{Binding AnimBuildObjectEndStart}" />
            
            <Label Content="Anim Build Object End End:" />
            <TextBox Text="{Binding AnimBuildObjectEndEnd}" />
            
            <!-- Normal digging animations -->
            <Label Content="Anim Dig Normal Start Start:" />
            <TextBox Text="{Binding AnimDigNormalStartStart}" />
            
            <Label Content="Anim Dig Normal Start End:" />
            <TextBox Text="{Binding AnimDigNormalStartEnd}" />
            
            <Label Content="Anim Dig Normal Work Start:" />
            <TextBox Text="{Binding AnimDigNormalWorkStart}" />
            
            <Label Content="Anim Dig Normal Work End:" />
            <TextBox Text="{Binding AnimDigNormalWorkEnd}" />
            
            <Label Content="Anim Dig Normal End Start:" />
            <TextBox Text="{Binding AnimDigNormalEndStart}" />
            
            <Label Content="Anim Dig Normal End End:" />
            <TextBox Text="{Binding AnimDigNormalEndEnd}" />
            
            <!-- Low digging animations -->
            <Label Content="Anim Dig Low Start Start:" />
            <TextBox Text="{Binding AnimDigLowStartStart}" />
            
            <Label Content="Anim Dig Low Start End:" />
            <TextBox Text="{Binding AnimDigLowStartEnd}" />
            
            <Label Content="Anim Dig Low Work Start:" />
            <TextBox Text="{Binding AnimDigLowWorkStart}" />
            
            <Label Content="Anim Dig Low Work End:" />
            <TextBox Text="{Binding AnimDigLowWorkEnd}" />
            
            <Label Content="Anim Dig Low End Start:" />
            <TextBox Text="{Binding AnimDigLowEndStart}" />
            
            <Label Content="Anim Dig Low End End:" />
            <TextBox Text="{Binding AnimDigLowEndEnd}" />
            
            <Label Content="Dig Smoke Id:" />
            <TextBox Text="{Binding DigSmokeId}" />
            
            <!-- From EquipableEntity -->
            <Label Content="Sight Range:" />
            <TextBox Text="{Binding SightRange}" />

            <Label Content="Talk Pack Id:" />
            <TextBox Text="{Binding TalkPackId}" />

            <Label Content="Shield Generator Id:" />
            <TextBox Text="{Binding ShieldGeneratorId}" />

            <Label Content="Max Shield Update:" />
            <TextBox Text="{Binding MaxShieldUpdate}" />

            <Label Content="Slot 1 Type:" />
            <TextBox Text="{Binding Slot1Type}" />

            <Label Content="Slot 2 Type:" />
            <TextBox Text="{Binding Slot2Type}" />

            <Label Content="Slot 3 Type:" />
            <TextBox Text="{Binding Slot3Type}" />

            <Label Content="Slot 4 Type:" />
            <TextBox Text="{Binding Slot4Type}" />

            <!-- From DestructibleEntity -->
            <Label Content="HP:" />
            <TextBox Text="{Binding HP}" />

            <Label Content="Hp Regeneration:" />
            <TextBox Text="{Binding HpRegeneration}" />

            <Label Content="Armor:" />
            <TextBox Text="{Binding Armor}" />

            <Label Content="Calorific Capacity:" />
            <TextBox Text="{Binding CalorificCapacity}" />

            <Label Content="Disable Resist:" />
            <TextBox Text="{Binding DisableResist}" />

            <Label Content="Storeable Flags:" />
            <TextBox Text="{Binding StoreableFlags}" />

            <Label Content="Stand Type:" />
            <TextBox Text="{Binding StandType}" />

            <!-- From InteractableEntity -->
            <Label Content="Mesh:" />
            <TextBox Text="{Binding Mesh}" />

            <Label Content="Shadow Type:" />
            <TextBox Text="{Binding ShadowType}" />

            <Label Content="View Params Index:" />
            <TextBox Text="{Binding ViewParamsIndex}" />

            <Label Content="Cost:" />
            <TextBox Text="{Binding Cost}" />

            <Label Content="Time Of Build:" />
            <TextBox Text="{Binding TimeOfBuild}" />

            <Label Content="Sound Pack Id:" />
            <TextBox Text="{Binding SoundPackId}" />

            <Label Content="Smoke Id:" />
            <TextBox Text="{Binding SmokeId}" />

            <Label Content="Kill Explosion Id:" />
            <TextBox Text="{Binding KillExplosionId}" />

            <Label Content="Destructed Id:" />
            <TextBox Text="{Binding DestructedId}" />

            <!-- From Entity -->
            <Label Content="Class Id:" />
            <TextBox Text="{Binding ClassId}" />

            <Label Content="Required Research:" />
            <ItemsControl ItemsSource="{Binding RequiredResearch}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding}" Margin="2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
