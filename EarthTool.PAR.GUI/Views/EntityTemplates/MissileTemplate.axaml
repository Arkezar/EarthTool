<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EarthTool.PAR.GUI.ViewModels.Details"
             x:Class="EarthTool.PAR.GUI.Views.EntityTemplates.MissileTemplate"
             x:DataType="vm:MissileViewModel">
    <ScrollViewer>
        <StackPanel Margin="10">
            <Label Content="Missile Details:" FontWeight="Bold" FontSize="16" />
            
            <Label Content="Name:" />
            <TextBox Text="{Binding Name}" />
            
            <Label Content="Type:" />
            <TextBox Text="{Binding Type}" />
            
            <Label Content="Rocket Type:" />
            <TextBox Text="{Binding RocketType}" />
            
            <Label Content="Missile Size:" />
            <TextBox Text="{Binding MissileSize}" />
            
            <Label Content="Rocket Dummy Id:" />
            <TextBox Text="{Binding RocketDummyId}" />
            
            <Label Content="Is Anti Rocket Target:" />
            <TextBox Text="{Binding IsAntiRocketTarget}" />
            
            <Label Content="Speed:" />
            <TextBox Text="{Binding Speed}" />
            
            <Label Content="Time Of Shoot:" />
            <TextBox Text="{Binding TimeOfShoot}" />
            
            <Label Content="Plus Range Of Fire:" />
            <TextBox Text="{Binding PlusRangeOfFire}" />
            
            <Label Content="Hit Type:" />
            <TextBox Text="{Binding HitType}" />
            
            <Label Content="Hit Range:" />
            <TextBox Text="{Binding HitRange}" />
            
            <Label Content="Type Of Damage:" />
            <TextBox Text="{Binding TypeOfDamage}" />
            
            <Label Content="Damage:" />
            <TextBox Text="{Binding Damage}" />
            
            <Label Content="Explosion Id:" />
            <TextBox Text="{Binding ExplosionId}" />
            
            <!-- From DestructibleEntity -->
            <Label Content="HP:" />
            <TextBox Text="{Binding HP}" />

            <Label Content="Hp Regeneration:" />
            <TextBox Text="{Binding HpRegeneration}" />

            <Label Content="Armor:" />
            <TextBox Text="{Binding Armor}" />

            <Label Content="Calorific Capacity:" />
            <TextBox Text="{Binding CalorificCapacity}" />

            <Label Content="Disable Resist:" />
            <TextBox Text="{Binding DisableResist}" />

            <Label Content="Storeable Flags:" />
            <TextBox Text="{Binding StoreableFlags}" />

            <Label Content="Stand Type:" />
            <TextBox Text="{Binding StandType}" />

            <!-- From InteractableEntity -->
            <Label Content="Mesh:" />
            <TextBox Text="{Binding Mesh}" />

            <Label Content="Shadow Type:" />
            <TextBox Text="{Binding ShadowType}" />

            <Label Content="View Params Index:" />
            <TextBox Text="{Binding ViewParamsIndex}" />

            <Label Content="Cost:" />
            <TextBox Text="{Binding Cost}" />

            <Label Content="Time Of Build:" />
            <TextBox Text="{Binding TimeOfBuild}" />

            <Label Content="Sound Pack Id:" />
            <TextBox Text="{Binding SoundPackId}" />

            <Label Content="Smoke Id:" />
            <TextBox Text="{Binding SmokeId}" />

            <Label Content="Kill Explosion Id:" />
            <TextBox Text="{Binding KillExplosionId}" />

            <Label Content="Destructed Id:" />
            <TextBox Text="{Binding DestructedId}" />

            <!-- From Entity -->
            <Label Content="Class Id:" />
            <TextBox Text="{Binding ClassId}" />

            <Label Content="Required Research:" />
            <ItemsControl ItemsSource="{Binding RequiredResearch}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding}" Margin="2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
