<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EarthTool.PAR.GUI.ViewModels.Details"
             x:Class="EarthTool.PAR.GUI.Views.EntityTemplates.RepairerTemplate"
             x:DataType="vm:RepairerViewModel">
    <ScrollViewer>
        <StackPanel Margin="10">
            <Label Content="Repairer Details:" FontWeight="Bold" FontSize="16" />
            
            <Label Content="Name:" />
            <TextBox Text="{Binding Name}" />
            
            <Label Content="Range Of Sight:" />
            <TextBox Text="{Binding RangeOfSight}" />
            
            <Label Content="Plug Type:" />
            <TextBox Text="{Binding PlugType}" />
            
            <Label Content="Slot Type:" />
            <TextBox Text="{Binding SlotType}" />
            
            <Label Content="Max Alpha Per Tick:" />
            <TextBox Text="{Binding MaxAlphaPerTick}" />
            
            <Label Content="Max Beta Per Tick:" />
            <TextBox Text="{Binding MaxBetaPerTick}" />
            
            <Label Content="Repairer Capabilities:" />
            <TextBox Text="{Binding RepairerCapabilities}" />
            
            <Label Content="Repair HP Per Tick:" />
            <TextBox Text="{Binding RepairHPPerTick}" />
            
            <Label Content="Repair Electronics Per Tick:" />
            <TextBox Text="{Binding RepairElectronicsPerTick}" />
            
            <Label Content="Ticks Per Repair:" />
            <TextBox Text="{Binding TicksPerRepair}" />
            
            <Label Content="Convert Tank Time:" />
            <TextBox Text="{Binding ConvertTankTime}" />
            
            <Label Content="Convert Building Time:" />
            <TextBox Text="{Binding ConvertBuildingTime}" />
            
            <Label Content="Convert Healthy Tank Time:" />
            <TextBox Text="{Binding ConvertHealthyTankTime}" />
            
            <Label Content="Convert Healthy Building Time:" />
            <TextBox Text="{Binding ConvertHealthyBuildingTime}" />
            
            <Label Content="Repaint Tank Time:" />
            <TextBox Text="{Binding RepaintTankTime}" />
            
            <Label Content="Repaint Building Time:" />
            <TextBox Text="{Binding RepaintBuildingTime}" />
            
            <Label Content="Upgrade Tank Time:" />
            <TextBox Text="{Binding UpgradeTankTime}" />
            
            <!-- Z InteractableEntity -->
            <Label Content="Mesh:" />
            <TextBox Text="{Binding Mesh}" />
            
            <Label Content="Shadow Type:" />
            <TextBox Text="{Binding ShadowType}" />
            
            <Label Content="View Params Index:" />
            <TextBox Text="{Binding ViewParamsIndex}" />
            
            <Label Content="Cost:" />
            <TextBox Text="{Binding Cost}" />
            
            <Label Content="Time Of Build:" />
            <TextBox Text="{Binding TimeOfBuild}" />
            
            <Label Content="Sound Pack Id:" />
            <TextBox Text="{Binding SoundPackId}" />
            
            <Label Content="Smoke Id:" />
            <TextBox Text="{Binding SmokeId}" />
            
            <Label Content="Kill Explosion Id:" />
            <TextBox Text="{Binding KillExplosionId}" />
            
            <Label Content="Destructed Id:" />
            <TextBox Text="{Binding DestructedId}" />
            
            <!-- Z TypedEntity -->
            <Label Content="Class Id:" />
            <TextBox Text="{Binding ClassId}" />
            
            <!-- Z Entity -->
            <Label Content="Required Research:" />
            <ItemsControl ItemsSource="{Binding RequiredResearch}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding}" Margin="2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
