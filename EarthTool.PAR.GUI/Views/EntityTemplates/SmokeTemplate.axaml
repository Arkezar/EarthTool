<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:EarthTool.PAR.Models"
             x:Class="EarthTool.PAR.GUI.Views.EntityTemplates.SmokeTemplate"
             x:DataType="local:Smoke">
    <ScrollViewer>
        <StackPanel Margin="10">
            <Label Content="Smoke Details:" FontWeight="Bold" FontSize="16" />
            
            <Label Content="Name:" />
            <TextBox Text="{Binding Name}" />
            
            <Label Content="Mesh 1:" />
            <TextBox Text="{Binding Mesh1}" />
            
            <Label Content="Mesh 2:" />
            <TextBox Text="{Binding Mesh2}" />
            
            <Label Content="Mesh 3:" />
            <TextBox Text="{Binding Mesh3}" />
            
            <Label Content="Smoke Time 1:" />
            <TextBox Text="{Binding SmokeTime1}" />
            
            <Label Content="Smoke Time 2:" />
            <TextBox Text="{Binding SmokeTime2}" />
            
            <Label Content="Smoke Time 3:" />
            <TextBox Text="{Binding SmokeTime3}" />
            
            <Label Content="Smoke Frequency:" />
            <TextBox Text="{Binding SmokeFrequency}" />
            
            <Label Content="Starting Time:" />
            <TextBox Text="{Binding StartingTime}" />
            
            <Label Content="Smoking Time:" />
            <TextBox Text="{Binding SmokingTime}" />
            
            <Label Content="Ending Time:" />
            <TextBox Text="{Binding EndingTime}" />
            
            <Label Content="Smoke Up Speed:" />
            <TextBox Text="{Binding SmokeUpSpeed}" />
            
            <Label Content="New Smoke Distance:" />
            <TextBox Text="{Binding NewSmokeDistance}" />
            
            <!-- Z DestructibleEntity -->
            <Label Content="HP:" />
            <TextBox Text="{Binding HP}" />
            
            <Label Content="Hp Regeneration:" />
            <TextBox Text="{Binding HpRegeneration}" />
            
            <Label Content="Armor:" />
            <TextBox Text="{Binding Armor}" />
            
            <Label Content="Calorific Capacity:" />
            <TextBox Text="{Binding CalorificCapacity}" />
            
            <Label Content="Disable Resist:" />
            <TextBox Text="{Binding DisableResist}" />
            
            <Label Content="Storeable Flags:" />
            <TextBox Text="{Binding StoreableFlags}" />
            
            <Label Content="Stand Type:" />
            <TextBox Text="{Binding StandType}" />
            
            <!-- Z InteractableEntity -->
            <Label Content="Mesh:" />
            <TextBox Text="{Binding Mesh}" />
            
            <Label Content="Shadow Type:" />
            <TextBox Text="{Binding ShadowType}" />
            
            <Label Content="View Params Index:" />
            <TextBox Text="{Binding ViewParamsIndex}" />
            
            <Label Content="Cost:" />
            <TextBox Text="{Binding Cost}" />
            
            <Label Content="Time Of Build:" />
            <TextBox Text="{Binding TimeOfBuild}" />
            
            <Label Content="Sound Pack Id:" />
            <TextBox Text="{Binding SoundPackId}" />
            
            <Label Content="Smoke Id:" />
            <TextBox Text="{Binding SmokeId}" />
            
            <Label Content="Kill Explosion Id:" />
            <TextBox Text="{Binding KillExplosionId}" />
            
            <Label Content="Destructed Id:" />
            <TextBox Text="{Binding DestructedId}" />
            
            <!-- Z TypedEntity -->
            <Label Content="Class Id:" />
            <TextBox Text="{Binding ClassId}" />
            
            <!-- Z Entity -->
            <Label Content="Required Research:" />
            <ItemsControl ItemsSource="{Binding RequiredResearch}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBox Text="{Binding}" Margin="2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
