<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:EarthTool.PAR.Models"
             x:Class="EarthTool.PAR.GUI.Views.EntityTemplates.UnitTransporterTemplate"
             x:DataType="local:UnitTransporter">
    <ScrollViewer>
        <StackPanel Margin="10">
            <Label Content="Unit Transporter Details:" FontWeight="Bold" FontSize="16" />
            
            <Label Content="Name:" />
            <TextBox Text="{Binding Name}" />
            
            <Label Content="Vehicle Speed:" />
            <TextBox Text="{Binding VehicleSpeed}" />
            
            <Label Content="Vertical Vehicle Animation Type:" />
            <TextBox Text="{Binding VerticalVehicleAnimationType}" />
            
            <Label Content="Units Count:" />
            <TextBox Text="{Binding UnitsCount}" />
            
            <Label Content="Docking Height:" />
            <TextBox Text="{Binding DockingHeight}" />
            
            <Label Content="Anim Loading Start Start:" />
            <TextBox Text="{Binding AnimLoadingStartStart}" />
            
            <Label Content="Anim Loading Start End:" />
            <TextBox Text="{Binding AnimLoadingStartEnd}" />
            
            <Label Content="Anim Loading End Start:" />
            <TextBox Text="{Binding AnimLoadingEndStart}" />
            
            <Label Content="Anim Loading End End:" />
            <TextBox Text="{Binding AnimLoadingEndEnd}" />
            
            <Label Content="Anim Unloading Start Start:" />
            <TextBox Text="{Binding AnimUnloadingStartStart}" />
            
            <Label Content="Anim Unloading Start End:" />
            <TextBox Text="{Binding AnimUnloadingStartEnd}" />
            
            <Label Content="Anim Unloading End Start:" />
            <TextBox Text="{Binding AnimUnloadingEndStart}" />
            
            <Label Content="Anim Unloading End End:" />
            <TextBox Text="{Binding AnimUnloadingEndEnd}" />
            
            <!-- Z EquipableEntity -->
            <Label Content="Sight Range:" />
            <TextBox Text="{Binding SightRange}" />
            
            <Label Content="Talk Pack Id:" />
            <TextBox Text="{Binding TalkPackId}" />
            
            <Label Content="Shield Generator Id:" />
            <TextBox Text="{Binding ShieldGeneratorId}" />
            
            <Label Content="Max Shield Update:" />
            <TextBox Text="{Binding MaxShieldUpdate}" />
            
            <Label Content="Slot 1 Type:" />
            <TextBox Text="{Binding Slot1Type}" />
            
            <Label Content="Slot 2 Type:" />
            <TextBox Text="{Binding Slot2Type}" />
            
            <Label Content="Slot 3 Type:" />
            <TextBox Text="{Binding Slot3Type}" />
            
            <Label Content="Slot 4 Type:" />
            <TextBox Text="{Binding Slot4Type}" />
            
            <!-- Z DestructibleEntity -->
            <Label Content="HP:" />
            <TextBox Text="{Binding HP}" />
            
            <Label Content="HP Regeneration:" />
            <TextBox Text="{Binding HpRegeneration}" />
            
            <Label Content="Armor:" />
            <TextBox Text="{Binding Armor}" />
            
            <Label Content="Calorific Capacity:" />
            <TextBox Text="{Binding CalorificCapacity}" />
            
            <Label Content="Disable Resist:" />
            <TextBox Text="{Binding DisableResist}" />
            
            <Label Content="Storeable Flags:" />
            <TextBox Text="{Binding StoreableFlags}" />
            
            <Label Content="Stand Type:" />
            <TextBox Text="{Binding StandType}" />
            
            <!-- Z InteractableEntity -->
            <Label Content="Mesh:" />
            <TextBox Text="{Binding Mesh}" />
            
            <Label Content="Shadow Type:" />
            <TextBox Text="{Binding ShadowType}" />
            
            <Label Content="View Params Index:" />
            <TextBox Text="{Binding ViewParamsIndex}" />
            
            <Label Content="Cost:" />
            <TextBox Text="{Binding Cost}" />
            
            <Label Content="Time Of Build:" />
            <TextBox Text="{Binding TimeOfBuild}" />
            
            <Label Content="Sound Pack Id:" />
            <TextBox Text="{Binding SoundPackId}" />
            
            <Label Content="Smoke Id:" />
            <TextBox Text="{Binding SmokeId}" />
            
            <Label Content="Kill Explosion Id:" />
            <TextBox Text="{Binding KillExplosionId}" />
            
            <Label Content="Destructed Id:" />
            <TextBox Text="{Binding DestructedId}" />
            
            <!-- Z TypedEntity -->
            <Label Content="Class Id:" />
            <TextBox Text="{Binding ClassId}" />
            
            <!-- Z Entity -->
            <Label Content="Required Research:" />
            <TextBox Text="{Binding RequiredResearch}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
